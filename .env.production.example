# AuthClaw Lite production/private AWS deployment environment.
# Copy to .env.production and replace every placeholder before starting the stack.

# Runtime mode. Production startup checks fail closed if demo settings are left on.
AUTHCLAW_ENV=production
NEXT_PUBLIC_AUTHCLAW_DEMO_MODE=false
DEMO_OTP_VISIBLE=false
AUTHCLAW_COOKIE_SECURE=true
API_DEBUG=false

# Public URLs. These must be HTTPS in production.
NEXT_PUBLIC_API_URL=https://app.yourdomain.com
NEXT_PUBLIC_GATEWAY_URL=https://gateway.yourdomain.com
PUBLIC_GATEWAY_URL=https://gateway.yourdomain.com

# Local exposed ports on the host/EC2 instance.
# In production, expose 80/443 through a reverse proxy and keep these ports private.
BACKEND_PORT=8000
GATEWAY_PORT=8080
CONSOLE_PORT=3001
POSTGRES_PORT=5432
REDIS_PORT=6379
OPA_PORT=8181
PRESIDIO_PORT=3000

# Database. For a first private AWS demo, compose Postgres is acceptable.
# For stronger production posture, use RDS Postgres and set these URLs directly
# in the deployment environment instead of exposing the database port publicly.
POSTGRES_DB=authclaw
POSTGRES_USER=authclaw_owner
POSTGRES_PASSWORD=<replace-with-strong-owner-password>
POSTGRES_APP_USER=authclaw_app
POSTGRES_APP_PASSWORD=<replace-with-strong-app-password>

# Security secrets. Generate long random values. ENVELOPE_KEY must be at least 32 bytes.
JWT_SECRET=<replace-with-long-random-secret>
SESSION_SECRET=<replace-with-long-random-secret>
ENVELOPE_KEY=<replace-with-32-byte-minimum-random-secret>
KMS_KEY_ID=<aws-kms-key-id-or-production-key-label>

# Email OTP via Amazon SES SMTP.
# SES sender/domain must be verified before signup emails work.
SMTP_HOST=email-smtp.<aws-region>.amazonaws.com
SMTP_PORT=587
SMTP_USER=<ses-smtp-username>
SMTP_PASSWORD=<ses-smtp-password>
SMTP_FROM=no-reply@yourdomain.com
EMAIL_FROM=no-reply@yourdomain.com
SMTP_TLS=true

# Signup/OTP abuse limits.
ONBOARDING_SIGNUP_EMAIL_PER_HOUR=3
ONBOARDING_SIGNUP_IP_PER_DAY=10
ONBOARDING_VERIFY_IP_PER_HOUR=30

# Provider endpoints. Customers save their own provider keys in the vault.
# Do not set global provider API keys for tenant runtime traffic.
OPENAI_BASE_URL=https://api.openai.com
ANTHROPIC_BASE_URL=https://api.anthropic.com
COHERE_BASE_URL=https://api.cohere.ai
GEMINI_BASE_URL=https://generativelanguage.googleapis.com
GEMINI_API_KEY=

# Gateway runtime safety limits. Conservative defaults for private AWS pilot.
GATEWAY_RATE_LIMIT_ENABLED=true
GATEWAY_RATE_LIMIT_PER_MINUTE=30
GATEWAY_RATE_LIMIT_BURST_10S=10
GATEWAY_RATE_LIMIT_DAILY=1000
GATEWAY_MAX_BODY_BYTES=131072

# AWS feature flags. Keep off unless deliberately testing AWS connectors/Bedrock.
AWS_ENABLED=false
AWS_REGION=<aws-region>
AWS_SECRETS_MANAGER_ENABLED=false
BEDROCK_ENABLED=false
AWS_S3_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Optional ClickHouse/Kafka. Leave blank for Lite Postgres audit fallback.
CLICKHOUSE_HOST=
CLICKHOUSE_PORT=8123
CLICKHOUSE_DB=authclaw
CLICKHOUSE_USER=authclaw
CLICKHOUSE_PASSWORD=
KAFKA_BROKERS=
