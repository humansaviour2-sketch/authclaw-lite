# AuthClaw Lite demo environment.
# Copy to .env.demo on the EC2 instance or local machine and fill only what you need.

POSTGRES_DB=authclaw
POSTGRES_USER=authclaw
POSTGRES_PASSWORD=change-this-demo-password

BACKEND_PORT=8000
GATEWAY_PORT=8080
CONSOLE_PORT=3001
POSTGRES_PORT=5432
REDIS_PORT=6379
OPA_PORT=8181
PRESIDIO_PORT=3000

NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_GATEWAY_URL=http://localhost:8080
PUBLIC_GATEWAY_URL=http://localhost:8080
NEXT_PUBLIC_AUTHCLAW_DEMO_MODE=true
DEMO_OTP_VISIBLE=true
AUTHCLAW_ENV=demo
AUTHCLAW_COOKIE_SECURE=false

# Real email OTP delivery. For AWS deployment, use Amazon SES SMTP credentials.
# SMTP_HOST=email-smtp.<aws-region>.amazonaws.com
# SMTP_PORT=587
# SMTP_USER=<ses-smtp-username>
# SMTP_PASSWORD=<ses-smtp-password>
# SMTP_FROM=no-reply@yourdomain.com
# SMTP_TLS=true

JWT_SECRET=change-this-demo-jwt-secret
SESSION_SECRET=change-this-demo-session-secret
ENVELOPE_KEY=change-this-demo-envelope-key
KMS_KEY_ID=demo-local-key

# Production/AWS hardening:
# AUTHCLAW_ENV=production
# NEXT_PUBLIC_AUTHCLAW_DEMO_MODE=false
# DEMO_OTP_VISIBLE=false
# AUTHCLAW_COOKIE_SECURE=true
# NEXT_PUBLIC_GATEWAY_URL=https://gateway.yourdomain.com
# PUBLIC_GATEWAY_URL=https://gateway.yourdomain.com
# JWT_SECRET=<random-long-secret>
# SESSION_SECRET=<random-long-secret>
# ENVELOPE_KEY=<32+-byte-random-secret>

# Demo default: keep paid AWS/Bedrock integrations off.
AWS_ENABLED=false
BEDROCK_ENABLED=false
AWS_SECRETS_MANAGER_ENABLED=false

# Add only a test/sandbox provider key for demo traffic.
GEMINI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com
ANTHROPIC_BASE_URL=https://api.anthropic.com
COHERE_BASE_URL=https://api.cohere.ai
GEMINI_BASE_URL=https://generativelanguage.googleapis.com

# Gateway safety limits. These apply before provider egress to protect credits.
GATEWAY_RATE_LIMIT_ENABLED=true
GATEWAY_RATE_LIMIT_PER_MINUTE=30
GATEWAY_RATE_LIMIT_BURST_10S=10
GATEWAY_RATE_LIMIT_DAILY=1000
GATEWAY_MAX_BODY_BYTES=131072
GATEWAY_MAX_DAILY_SPEND_USD=5
GATEWAY_ESTIMATED_COST_PER_1K_REQUESTS_USD=1
