# AuthClaw Lite demo environment.
# Copy to .env.demo on the EC2 instance or local machine and fill only what you need.

POSTGRES_DB=authclaw
POSTGRES_USER=authclaw
POSTGRES_PASSWORD=change-this-demo-password

BACKEND_PORT=8000
GATEWAY_PORT=8080
CONSOLE_PORT=3001
POSTGRES_PORT=5432
REDIS_PORT=6379
OPA_PORT=8181
PRESIDIO_PORT=3000

NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_GATEWAY_URL=http://localhost:8080
NEXT_PUBLIC_AUTHCLAW_DEMO_MODE=true

JWT_SECRET=change-this-demo-jwt-secret
SESSION_SECRET=change-this-demo-session-secret
ENVELOPE_KEY=change-this-demo-envelope-key
KMS_KEY_ID=demo-local-key

# Demo default: keep paid AWS/Bedrock integrations off.
AWS_ENABLED=false
BEDROCK_ENABLED=false
AWS_SECRETS_MANAGER_ENABLED=false

# Add only a test/sandbox provider key for demo traffic.
GEMINI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com
ANTHROPIC_BASE_URL=https://api.anthropic.com
COHERE_BASE_URL=https://api.cohere.ai
GEMINI_BASE_URL=https://generativelanguage.googleapis.com
