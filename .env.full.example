# AuthClaw full local environment.
# Use with: docker compose --env-file .env.full -f docker-compose.full.yml up -d --build

POSTGRES_DB=authclaw
POSTGRES_USER=authclaw
POSTGRES_PASSWORD=authclaw
POSTGRES_APP_USER=authclaw_app
POSTGRES_APP_PASSWORD=authclaw_app

BACKEND_PORT=8000
GATEWAY_PORT=8080
CONSOLE_PORT=3001
POSTGRES_PORT=5432
REDIS_PORT=6379
OPA_PORT=8181
PRESIDIO_PORT=3000
KAFKA_PORT=9092
CLICKHOUSE_HTTP_PORT=8123
CLICKHOUSE_NATIVE_PORT=9000
AUDIT_CONSUMER_METRICS_PORT=9108

CLICKHOUSE_DB=authclaw
CLICKHOUSE_USER=authclaw
CLICKHOUSE_PASSWORD=authclaw

NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_GATEWAY_URL=http://localhost:8080
PUBLIC_GATEWAY_URL=http://localhost:8080
NEXT_PUBLIC_AUTHCLAW_DEMO_MODE=false
DEMO_OTP_VISIBLE=false
AUTHCLAW_ENV=local
AUTHCLAW_COOKIE_SECURE=false

JWT_SECRET=authclaw-full-local-jwt-secret
SESSION_SECRET=authclaw-full-local-session-secret
ENVELOPE_KEY=authclaw-full-local-envelope-key-v1
KMS_KEY_ID=full-local-key

AWS_ENABLED=false
BEDROCK_ENABLED=false
AWS_SECRETS_MANAGER_ENABLED=false

GEMINI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com
ANTHROPIC_BASE_URL=https://api.anthropic.com
COHERE_BASE_URL=https://api.cohere.ai
GEMINI_BASE_URL=https://generativelanguage.googleapis.com

GATEWAY_RATE_LIMIT_ENABLED=true
GATEWAY_RATE_LIMIT_PER_MINUTE=120
GATEWAY_RATE_LIMIT_BURST_10S=30
GATEWAY_RATE_LIMIT_DAILY=10000
GATEWAY_MAX_BODY_BYTES=1048576
GATEWAY_MAX_DAILY_SPEND_USD=25
GATEWAY_ESTIMATED_COST_PER_1K_REQUESTS_USD=1
AUDIT_FAIL_CLOSED=false
