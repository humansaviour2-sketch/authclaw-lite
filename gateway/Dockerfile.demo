ARG GO_VERSION=1.26.4
FROM golang:${GO_VERSION}-alpine AS build

WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN go build -o /out/authclaw-gateway .

FROM alpine:3.20
WORKDIR /app
RUN addgroup -S authclaw && adduser -S -G authclaw authclaw
COPY --from=build --chown=authclaw:authclaw /out/authclaw-gateway /app/authclaw-gateway

EXPOSE 8080

USER authclaw

CMD ["/app/authclaw-gateway"]
