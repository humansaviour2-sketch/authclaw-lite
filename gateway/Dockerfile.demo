ARG GO_VERSION=1.26.4
FROM golang:${GO_VERSION}-alpine AS build

WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN go build -o /out/authclaw-gateway .

FROM alpine:3.20
WORKDIR /app
COPY --from=build /out/authclaw-gateway /app/authclaw-gateway

EXPOSE 8080

CMD ["/app/authclaw-gateway"]
