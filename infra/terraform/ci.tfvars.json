{
  "project": "authclaw",
  "environment": "ci",
  "primary_region": "us-east-1",
  "secondary_region": "us-west-2",
  "primary_availability_zones": ["us-east-1a", "us-east-1b"],
  "secondary_availability_zones": ["us-west-2a", "us-west-2b"],
  "ci_skip_aws_validation": true,
  "container_images": {
    "backend": "ghcr.io/example/authclaw/backend:ci",
    "gateway": "ghcr.io/example/authclaw/gateway:ci",
    "console": "ghcr.io/example/authclaw/console:ci",
    "audit_consumer": "ghcr.io/example/authclaw/audit-consumer:ci",
    "opa": "ghcr.io/example/authclaw/opa-bundle:ci",
    "presidio": "mcr.microsoft.com/presidio-analyzer:latest"
  },
  "authclaw_env": "staging",
  "desired_count_primary": 1,
  "desired_count_secondary": 1,
  "enable_secondary": true,
  "enable_cross_region_db_replica": true,
  "certificate_arn": "arn:aws:acm:us-east-1:123456789012:certificate/00000000-0000-4000-8000-000000000000",
  "secondary_certificate_arn": "arn:aws:acm:us-west-2:123456789012:certificate/00000000-0000-4000-8000-000000000001",
  "enable_audit_consumer": true,
  "kafka_brokers": "b-1.authclaw-ci.local:9092",
  "clickhouse_host": "clickhouse.authclaw-ci.local",
  "clickhouse_password": "ci-placeholder",
  "tags": {
    "Environment": "ci",
    "Purpose": "terraform-plan"
  }
}
